# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real keys.

# ── Required ─────────────────────────────────────────────────────────────────
# DeepSeek API key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Optional: News APIs (leave blank to disable) ─────────────────────────────
# Finnhub free tier  (https://finnhub.io)
FINNHUB_API_KEY=

# MarketAux free tier (https://www.marketaux.com)
MARKETAUX_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file (default: news_agent.db in project root)
DB_PATH=news_agent.db

# Directory where daily Markdown reports are written (default: reports/)
REPORTS_DIR=reports
